---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home" homeLayout>
  <section
    class="hero relative flex min-h-[72vh] flex-col overflow-hidden bg-linear-to-t from-roll-gold from-7% to-roll-orange"
  >
    <!-- Gold V overlay -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div
        class="absolute bottom-0 left-1/2 h-[75%] w-[min(140%,900px)] -translate-x-1/2 bg-linear-to-t from-roll-gold/90 via-roll-gold/40 to-transparent"
        style="clip-path: polygon(50% 100%, 0 0, 100% 0);"
      >
      </div>
    </div>

    <!-- Characters -->
    <div
      class="hero-characters pointer-events-none absolute inset-x-0 top-0 bottom-0 z-10 hidden md:block"
      aria-hidden="true"
    >
      <img
        src="/images/Characters-04.png"
        alt=""
        class="hero-character hero-character--left"
        width="400"
        height="566"
        loading="eager"
      />
      <img
        src="/images/Characters-03.png"
        alt=""
        class="hero-character hero-character--right"
        width="400"
        height="566"
        loading="eager"
      />
    </div>

    <!-- Hero content -->
    <div
      class="relative z-20 mx-auto flex w-full max-w-[1410px] flex-1 flex-col items-center justify-center px-4 pb-16 pt-20 text-center sm:px-6 sm:pb-20 lg:px-8"
    >
      <!-- Mobile: figures replace logo (reversed vs desktop flanking) -->
      <div class="hero-characters-mobile mb-6 md:hidden" aria-hidden="true">
        <img
          src="/images/Characters-03.png"
          alt=""
          class="hero-character-mobile"
          width="400"
          height="566"
          loading="eager"
        />
        <img
          src="/images/Characters-04.png"
          alt=""
          class="hero-character-mobile"
          width="400"
          height="566"
          loading="eager"
        />
      </div>

      <img
        src="/images/Which-Roll-02.png"
        alt="Which Roll?"
        class="mb-8 hidden w-[min(85%,520px)] md:block"
        width="520"
        height="221"
        loading="eager"
      />

      <h1
        class="hero-intro mb-8 max-w-lg font-heading text-base leading-relaxed text-white sm:text-lg font-normal"
      >
        <span class="font-bold">Which Roll? – Ko Tēhea Rārangi Pōti?</span> was a
        short anonymous survey held in 2022 asking people why they choose the Māori
        or General electoral roll.
      </h1>

      <a
        href="/about-us/"
        class="inline-block rounded-full border border-roll-orange bg-roll-orange px-12 py-4 text-base font-semibold text-white no-underline transition-colors hover:border-white hover:bg-white hover:text-roll-text"
      >
        About us
      </a>
    </div>

    <!-- Bottom chevron -->
    <div class="hero-chevron" aria-hidden="true">
      <div class="hero-chevron__face hero-chevron__face--left"></div>
      <div class="hero-chevron__face hero-chevron__face--right"></div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initHeroCharacterPosition } from '../scripts/hero-character-position.ts';

  initHeroCharacterPosition();
</script>
