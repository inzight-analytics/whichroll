---
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicationCard from "../components/PublicationCard.astro";

const publications = [
  {
    title:
      "Indigenous Research Methods and Online Surveys: Designing an Online Survey to Give Voice to Māori Electoral Choices",
    citation:
      "Greaves, L., & Waymouth, M. (2024). Indigenous research methods and online surveys: designing an online survey to give voice to maori electoral choices. In <em>Sage Research Methods: Diversifying and Decolonizing Research</em>. SAGE Publications, Ltd.",
    image: "/images/SAGE-LINK-IMG.jpg",
    link: "https://methods.sagepub.com/case/indigenous-research-methods-and-online-surveys-designing-an-online",
    linkLabel: "Sage Research Methods",
  },
  {
    title:
      "Indigenous Representational Choices: Results from a Large Qualitative Survey on Māori Electoral Roll Choice",
    citation:
      "Greaves, L. M., Hini, R., Overbye, H. R., &amp; Brink, K. G. (2025). Indigenous Representational Choices: Results from a Large Qualitative Survey on Māori Electoral Roll Choice. <em>The Journal of Race, Ethnicity, and Politics</em>, 10(2), 290–311.",
    link: "https://www.cambridge.org/core/journals/journal-of-race-ethnicity-and-politics/article/indigenous-representational-choices-results-from-a-large-qualitative-survey-on-maori-electoral-roll-choice/DBD58036E4B6A17D495496616CC4C4B0",
    linkLabel: "The Journal of Race, Ethnicity, and Politics",
    image: "/images/under-review-image.jpg",
  },
  {
    title:
      '[UNDER REVIEW] "Where do I enrol for my special treatment?" The effects of public pushback on an online Māori Electoral roll survey project',
    citation:
      "Brink, K., Barton, B., de Silva, T., Tuakoi, E., Oldfield, L. D., Waymouth, M., &amp; Greaves, L. M.",
    image: "/images/under-review-image.jpg",
  },
];

const grantPublications = [
  {
    title: "Resisting the Red Wave? The Māori Party's return to parliament.",
    citation:
      "In J. Curtin, L. Greaves, &amp; J. Vowles, <em>A Team of Five Million? The 2020 &lsquo;Covid-19&rsquo; New Zealand General Election.</em> ANU Press.",
    link: "https://press.anu.edu.au/publications/team-five-million#tabanchor",
    linkLabel: "ANU Press",
  },
  {
    title:
      "The predictors of Māori electoral roll choice and knowledge: Rangatahi Māori voter enrolment in a representative New Zealand youth survey.",
    citation:
      "Greaves, L. M., Hayward, J., Barnett, D., Crengle, S., &amp; Clark, T. C. (2023). <em>Kōtuitui: New Zealand Journal of Social Sciences Online, 18</em>(3), 290-309.",
  },
  {
    title: "Māori and the 2020 General Election",
    citation:
      "In S Levine (Ed.), <em>Politics in a Pandemic: Jacinda Ardern and the 2020 Election</em>. Wellington, NZ: Victoria University Press.",
  },
];
---

<BaseLayout
  title="Publications"
  showPageBanner={false}
  description="Research publications from the Which Roll? project."
>
  <section
    class="about-hero about-hero--title-only"
    aria-labelledby="publications-heading"
  >
    <div class="container about-hero__grid">
      <h1 id="publications-heading" class="about-hero__title">Publications</h1>
    </div>
  </section>

  <section class="publications-featured">
    <div class="container--site publications-featured__grid">
      {
        publications.map(({ title, citation, image, link, linkLabel }) => (
          <PublicationCard
            title={title}
            citation={citation}
            image={image}
            link={link}
            linkLabel={linkLabel}
          />
        ))
      }
    </div>
  </section>

  <section class="publications-grant-banner" aria-labelledby="grant-heading">
    <h2 id="grant-heading" class="publications-grant-banner__title">
      Publications supported by this grant
    </h2>
  </section>

  <section class="publications-grant section">
    <div class="container--site publications-grant__list">
      {
        grantPublications.map(({ title, citation, link, linkLabel }) => (
          <article class="publication-grant-item">
            <h2 class="publication-grant-item__title">{title}</h2>
            <div class="publication-grant-item__citation" set:html={citation} />
            {link && linkLabel && (
              <a
                class="publication-grant-item__link"
                href={link}
                target="_blank"
                rel="noopener"
              >
                {linkLabel}
              </a>
            )}
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
