---
import Header from '../components/Header.astro';
import PageBanner from '../components/PageBanner.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/base';
import '../styles/global.css';

interface Props {
  title: string;
  /** Page banner heading; defaults to `title` when omitted */
  bannerTitle?: string;
  /** Set false for pages with a custom intro header (e.g. About Us) */
  showPageBanner?: boolean;
  description?: string;
  ogImage?: string;
  homeLayout?: boolean;
}

const {
  title,
  bannerTitle,
  showPageBanner = true,
  description = 'A short anonymous survey asking people why they choose the Māori or General electoral roll.',
  ogImage = '/images/og-image-cover.jpg',
  homeLayout = false,
} = Astro.props;

const pageBannerTitle = bannerTitle ?? title;

const fullTitle = title === 'Home' ? 'Which Roll? – Ko Tēhea Rārangi Pōti?' : `${title} – Which Roll?`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(withBase(ogImage), Astro.site);
const imageStrip18 = `url("${withBase('/images/Which-Roll-Design-Strip-18.png')}")`;
const imageStrip19 = `url("${withBase('/images/Which-Roll-Design-Strip-19.png')}")`;
---

<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={withBase('/images/cropped-Favicon-32x32.png')} sizes="32x32" />
    <link rel="apple-touch-icon" href={withBase('/images/cropped-Favicon-180x180.png')} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Open+Sans:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <title>{fullTitle}</title>
    <style is:global define:vars={{ imageStrip18, imageStrip19 }}>
      :root {
        --image-strip-18: var(--imageStrip18);
        --image-strip-19: var(--imageStrip19);
      }
    </style>
  </head>
  <body class:list={[homeLayout ? 'bg-[#f35d15]' : 'bg-white', 'flex min-h-screen flex-col']}>
    <Header variant={homeLayout ? 'overlay' : 'solid'} />
    <main class="flex-1">
      {!homeLayout && showPageBanner && <PageBanner title={pageBannerTitle} />}
      <slot />
    </main>
    <Footer />
  </body>
</html>
