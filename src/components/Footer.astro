---
import { homeHref, navItems } from '../config/nav';
import { withBase } from '../utils/base';

const currentPath = Astro.url.pathname;
---

<footer class="bg-gradient-to-r from-[#f34315] to-[#f28729]">
  <div class="mx-auto flex min-h-[70px] max-w-[1600px] flex-col items-center justify-between gap-4 px-4 py-4 sm:flex-row sm:px-6 lg:px-8">
    <nav aria-label="Footer navigation">
      <ul class="flex flex-wrap items-center gap-x-6 gap-y-2">
        {
          navItems.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm font-semibold text-white no-underline hover:text-roll-text sm:text-base"
                aria-current={currentPath === href ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a href={homeHref} class="shrink-0" aria-label="Which Roll? home">
      <img
        src={withBase('/images/single-lol-qvbhwhz9u5pz0yacb7z4q2u0zottvqzplxa0uza4xg.png')}
        alt=""
        class="h-10 w-10"
        width="40"
        height="40"
      />
    </a>
  </div>
</footer>
