---
import { navItems } from '../config/nav';

interface Props {
  variant?: 'overlay' | 'solid';
}

const { variant = 'solid' } = Astro.props;
const currentPath = Astro.url.pathname;
const isOverlay = variant === 'overlay';
---

<header
  class:list={[
    'relative z-50 w-full',
    isOverlay ? 'absolute inset-x-0 top-0 bg-transparent' : 'bg-[#f35d15]',
  ]}
>
  <div class="mx-auto flex max-w-[1410px] items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="shrink-0" aria-label="Which Roll? home">
      <img
        src="/images/Which-Roll-02.png"
        alt="Which Roll? – Ko Tēhea Rārangi Pōti?"
        class="h-[110px] w-auto"
        width="280"
        height="119"
      />
    </a>

    <button
      type="button"
      id="nav-toggle"
      class="inline-flex flex-col items-center justify-center gap-1.5 rounded-md bg-roll-gold p-2.5 lg:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="site-nav"
    >
      <span class="block h-0.5 w-6 bg-white"></span>
      <span class="block h-0.5 w-6 bg-white"></span>
      <span class="block h-0.5 w-6 bg-white"></span>
    </button>

    <nav
      id="site-nav"
      class="hidden lg:block"
      aria-label="Main navigation"
    >
      <ul class="flex items-center gap-1 xl:gap-2">
        {
          navItems.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'block rounded-md px-3 py-2 text-sm font-semibold no-underline xl:px-4 xl:text-base',
                  currentPath === href
                    ? 'bg-roll-gold text-roll-text'
                    : 'text-white hover:bg-roll-gold hover:text-roll-text',
                ]}
                aria-current={currentPath === href ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <!-- Mobile menu -->
  <nav
    id="site-nav-mobile"
    class="hidden border-t border-white/20 bg-[#f35d15] lg:hidden"
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col px-4 py-3">
      {
        navItems.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'block rounded-md px-3 py-3 text-base font-semibold no-underline',
                currentPath === href
                  ? 'bg-roll-gold text-roll-text'
                  : 'text-white hover:bg-roll-gold hover:text-roll-text',
              ]}
              aria-current={currentPath === href ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('site-nav-mobile');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
